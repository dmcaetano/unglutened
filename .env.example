# UnGlutened environment variables
# Copy this file to .env and fill in the real values.

# Port the server listens on (Render provides this automatically in production).
PORT=3000

# Neon Postgres connection string. MUST include ?sslmode=require.
# Get this from the Neon dashboard (Connection Details → "Connection string").
DATABASE_URL=postgresql://user:password@ep-xxxx-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Postgres schema all tables live under. Defaults to "unglutened" if unset.
DB_SCHEMA=unglutened

# OpenRouter API key (https://openrouter.ai/keys). Required for AI photo analysis + chatbot.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vision model for photo -> ingredients (cheap, vision-capable).
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash-lite

# Chat model for the chatbot (cheap, supports tool-calling; text-only).
OPENROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash

# If set, the app requires this password to log in. Leave unset for an open app.
APP_PASSWORD=

# Secret used to sign the auth session cookie. Set a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Public URL of the deployed app, sent to OpenRouter as the HTTP-Referer header.
PUBLIC_URL=http://localhost:3000
